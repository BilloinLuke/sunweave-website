# Environment variables for the SUNWEAVE beach towel site
# Copy this file to .env and fill in your real values.
# DO NOT commit .env to Git.

# Google AI Studio (Gemini) API key
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model. Examples: gemini-2.0-flash, gemini-2.5-flash-preview-05-20, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# Optional: restrict CORS to your production domain
# ALLOWED_ORIGIN=https://www.sunweave.example.com
ALLOWED_ORIGIN=*

# ---- Chat provider ----
# Default is DeepSeek (cheaper, text-only). Switch to gemini by setting
# CHAT_PROVIDER=gemini and filling GEMINI_API_KEY above.
CHAT_PROVIDER=deepseek

# DeepSeek key — required when CHAT_PROVIDER=deepseek
# Get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---- Proxy (only if node server.js can't reach the internet directly) ----
# macOS system proxy is used by browsers but NOT by `node`. If the chat fails
# with a network error, set your proxy (Clash/Shadowrocket often 7890):
# CHAT_PROXY_URL=http://127.0.0.1:7890
CHAT_PROXY_URL=
